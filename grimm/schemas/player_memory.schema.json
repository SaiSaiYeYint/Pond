{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Grimm Player Memory",
  "type": "object",
  "required": ["playerId", "version", "facts", "preferences", "patterns", "goals", "relationship", "updatedAt"],
  "properties": {
    "playerId": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "facts": { "type": "array", "items": { "$ref": "#/$defs/memoryItem" } },
    "preferences": { "type": "array", "items": { "$ref": "#/$defs/memoryItem" } },
    "patterns": { "type": "array", "items": { "$ref": "#/$defs/memoryItem" } },
    "goals": { "type": "array", "items": { "$ref": "#/$defs/goalItem" } },
    "relationship": { "type": "array", "items": { "$ref": "#/$defs/memoryItem" } },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "memoryItem": {
      "type": "object",
      "required": ["id", "text", "confidence", "source", "createdAt", "updatedAt"],
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "source": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "goalItem": {
      "type": "object",
      "required": ["id", "text", "date", "status", "createdAt"],
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "date": { "type": "string" },
        "status": { "enum": ["active", "reached", "missed", "abandoned"] },
        "evidence": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}

