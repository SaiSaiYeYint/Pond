{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Grimm Notebook",
  "type": "object",
  "required": ["entries"],
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text", "basis", "tags", "visibility", "createdAt"],
        "properties": {
          "id": { "type": "string" },
          "text": { "type": "string" },
          "basis": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "visibility": { "enum": ["private", "work_time_candidate", "constitution_candidate"] },
          "promotedToConstitution": { "type": "boolean" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
